# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz

# Same as license-server (admin web)
ADMIN_API_KEY=change-me-strong-secret

# License API base URL (no trailing slash)
LICENSE_API_BASE_URL=https://lohastudioadmin.vercel.app

# Optional: comma-separated Telegram user IDs allowed to use the bot.
# Leave empty to allow all users. Get your ID from @userinfobot
# TELEGRAM_ALLOWED_IDS=123456789,987654321

# Default product flags when /key is used WITHOUT veo/grok/sora on the command line.
# Same names as license API: veo (Veo3), grok (Grok Imagine), sora (Sora).
# DEFAULT_MODELS=veo,grok
